<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UIDeviceFamily</key>
	<array>
		<integer>1</integer>
		<integer>2</integer>
	</array>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>XSAppIconAssets</key>
	<string>Assets.xcassets/appicon.appiconset</string>

	<!--
	  Background modes required by Firebase Cloud Messaging.

	  - "remote-notification" — lets iOS deliver silent / data pushes to
	    DidReceiveRemoteNotification while the app is suspended, which is
	    how FCM forwards data-only payloads.
	  - "fetch" — lets the OS occasionally wake the app for background
	    fetch; the FCM SDK uses this to keep the registration token
	    fresh even when the user hasn't opened the app for a while.
	-->
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
		<string>fetch</string>
	</array>

	<!--
	  Disable FCM's UIApplicationDelegate method swizzling. We forward
	  the APNs token to FCM ourselves from AppDelegate.RegisteredForRemoteNotifications,
	  which keeps the token-flow plumbing explicit and matches the way
	  the Android side delivers tokens via MyFirebaseMessagingService.
	-->
	<key>FirebaseAppDelegateProxyEnabled</key>
	<false/>
</dict>
</plist>
