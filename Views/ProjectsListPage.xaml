<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TestHub.ViewModels"
             x:Class="TestHub.Views.ProjectsListPage"
             x:Name="ProjectsRoot"
             x:DataType="vm:ProjectsListViewModel"
             Shell.NavBarIsVisible="False"
             Shell.FlyoutBehavior="Disabled"
             Shell.TabBarIsVisible="False"
             BackgroundColor="{StaticResource CardBg}">

    <ContentPage.Resources>
        <Color x:Key="MutedText">#94A3B8</Color>
        <Color x:Key="LabelText">#64748B</Color>
        <Color x:Key="TabIconMuted">#9AA3B5</Color>
        <Color x:Key="TabActiveBg">#FBE6B7</Color>
        <Color x:Key="NotifDot">#EF4444</Color>
    </ContentPage.Resources>

    <Grid>

        <!-- ============================================================ -->
        <!-- BODY (navy header scrolls with the list)                       -->
        <!-- ============================================================ -->
        <RefreshView IsRefreshing="{Binding IsBusy, Mode=OneWay}"
                     Command="{Binding RefreshCommand}">
            <CollectionView ItemsSource="{Binding Items}"
                            SelectionMode="None"
                            RemainingItemsThreshold="3"
                            RemainingItemsThresholdReachedCommand="{Binding LoadMoreCommand}">

                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
                </CollectionView.ItemsLayout>

                <!-- ===================== HEADER (navy title + search bar) ===================== -->
                <CollectionView.Header>
                    <VerticalStackLayout Spacing="14">
                        <!-- Navy header — scrolls with content (no longer sticky) -->
                        <Border BackgroundColor="{StaticResource BrandNavy}"
                                Stroke="Transparent"
                                StrokeThickness="0"
                                Padding="24,40,24,28">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="0,0,28,28" />
                            </Border.StrokeShape>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="{StaticResource BrandNavyLight}" Offset="0.0" />
                                    <GradientStop Color="{StaticResource BrandNavy}"      Offset="1.0" />
                                </LinearGradientBrush>
                            </Border.Background>

                            <Label Text="Projects"
                                   TextColor="{StaticResource White}"
                                   FontSize="28"
                                   FontAttributes="Bold"
                                   FontFamily="OpenSansSemibold"
                                   VerticalOptions="Center" />
                        </Border>

                        <!-- Search bar -->
                        <Border BackgroundColor="{StaticResource White}"
                                Stroke="#EAECF2"
                                StrokeThickness="1"
                                Padding="16,12"
                                Margin="16,4,16,0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                <Image Grid.Column="0"
                                       Source="icon_search.png"
                                       WidthRequest="18"
                                       HeightRequest="18"
                                       VerticalOptions="Center" />
                                <Entry Grid.Column="1"
                                       Placeholder="Search projects"
                                       PlaceholderColor="{StaticResource MutedText}"
                                       TextColor="{StaticResource BrandNavy}"
                                       FontSize="14"
                                       BackgroundColor="Transparent"
                                       ReturnType="Search"
                                       Text="{Binding SearchTerm, Mode=TwoWay}"
                                       ReturnCommand="{Binding SearchCommand}"
                                       VerticalOptions="Center" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>
                </CollectionView.Header>

                <!-- ===================== ITEM TEMPLATE ===================== -->
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:QuoteListItemViewModel">
                        <Border BackgroundColor="{StaticResource White}"
                                Stroke="#EAECF2"
                                StrokeThickness="1"
                                Padding="16"
                                Margin="16,0,16,0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding BindingContext.OpenProjectCommand, Source={x:Reference ProjectsRoot}}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>

                            <VerticalStackLayout Spacing="10">

                                <!-- Title + customer -->
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="{Binding ProjectName}"
                                           TextColor="{StaticResource BrandNavy}"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           FontFamily="OpenSansSemibold" />
                                    <Label Text="{Binding CustomerName}"
                                           TextColor="{StaticResource LabelText}"
                                           FontSize="13" />
                                </VerticalStackLayout>

                                <BoxView HeightRequest="1" Color="#F1F5F9" Margin="0,2,0,0" />

                                <!-- Amount / Date / Type / chevron -->
                                <Grid ColumnDefinitions="*,*,*,Auto" ColumnSpacing="8">
                                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                                        <Label Text="Amount"
                                               TextColor="{StaticResource MutedText}"
                                               FontSize="11" />
                                        <Label Text="{Binding AmountDisplay}"
                                               TextColor="{StaticResource BrandNavy}"
                                               FontSize="14"
                                               FontAttributes="Bold"
                                               FontFamily="OpenSansSemibold" />
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                                        <Label Text="Date"
                                               TextColor="{StaticResource MutedText}"
                                               FontSize="11" />
                                        <Label Text="{Binding DateDisplay}"
                                               TextColor="{StaticResource BrandNavy}"
                                               FontSize="14"
                                               FontAttributes="Bold"
                                               FontFamily="OpenSansSemibold" />
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Column="2" Spacing="2">
                                        <Label Text="Type"
                                               TextColor="{StaticResource MutedText}"
                                               FontSize="11" />
                                        <Label Text="{Binding ProjectType}"
                                               TextColor="{StaticResource BrandNavy}"
                                               FontSize="14"
                                               FontAttributes="Bold"
                                               FontFamily="OpenSansSemibold" />
                                    </VerticalStackLayout>

                                    <Image Grid.Column="3"
                                           Source="icon_chevron_right.png"
                                           WidthRequest="18"
                                           HeightRequest="18"
                                           VerticalOptions="Center" />
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <!-- ===================== FOOTER ===================== -->
                <CollectionView.Footer>
                    <VerticalStackLayout Padding="16,14,16,110" Spacing="8">
                        <ActivityIndicator IsRunning="{Binding IsLoadingMore}"
                                           IsVisible="{Binding IsLoadingMore}"
                                           Color="{StaticResource BrandGold}"
                                           HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </CollectionView.Footer>

                <!-- ===================== EMPTY STATE ===================== -->
                <CollectionView.EmptyView>
                    <Grid Padding="24,40">
                        <VerticalStackLayout Spacing="10" HorizontalOptions="Center" VerticalOptions="Center">
                            <Image Source="icon_doc_tile.png"
                                   WidthRequest="56"
                                   HeightRequest="56"
                                   HorizontalOptions="Center"
                                   Opacity="0.7" />
                            <Label Text="No projects yet"
                                   TextColor="{StaticResource BrandNavy}"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   FontFamily="OpenSansSemibold"
                                   HorizontalTextAlignment="Center" />
                            <Label Text="Projects will appear here once you create quotes."
                                   TextColor="{StaticResource MutedText}"
                                   FontSize="12"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Grid>
                </CollectionView.EmptyView>
            </CollectionView>
        </RefreshView>

        <!-- ============================================================ -->
        <!-- TAB BAR (floating rounded pill, Projects active)               -->
        <!-- ============================================================ -->
        <Border BackgroundColor="{StaticResource White}"
                Stroke="#EAECF2"
                StrokeThickness="1"
                Padding="12,8,12,8"
                Margin="14,0,14,16"
                HorizontalOptions="Fill"
                VerticalOptions="End">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="32" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Opacity="0.12" Radius="18" Offset="0,4" />
            </Border.Shadow>

            <Grid ColumnDefinitions="*,*,*,*,*" ColumnSpacing="4">

                <!-- Home -->
                <VerticalStackLayout Grid.Column="0"
                                     Padding="0,8"
                                     HorizontalOptions="Center"
                                     Spacing="4"
                                     AutomationId="ProjectsTabHome">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoHomeCommand}" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="tab_home.png" WidthRequest="22" HeightRequest="22" />
                    <Label Text="Home" TextColor="{StaticResource TabIconMuted}" FontSize="11" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <!-- Projects (active) -->
                <Border Grid.Column="1"
                        BackgroundColor="{StaticResource TabActiveBg}"
                        Stroke="Transparent"
                        Padding="0,8"
                        AutomationId="ProjectsTabProjects">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14" />
                    </Border.StrokeShape>
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                        <Grid WidthRequest="24" HeightRequest="24" HorizontalOptions="Center">
                            <Image Source="tab_projects.png"
                                   WidthRequest="22"
                                   HeightRequest="22" />
                            <Ellipse Fill="{StaticResource NotifDot}"
                                     WidthRequest="6"
                                     HeightRequest="6"
                                     HorizontalOptions="End"
                                     VerticalOptions="Start" />
                        </Grid>
                        <Label Text="Projects"
                               TextColor="{StaticResource BrandNavy}"
                               FontSize="11"
                               FontAttributes="Bold"
                               FontFamily="OpenSansSemibold"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

                <!-- Invoices -->
                <VerticalStackLayout Grid.Column="2"
                                     Padding="0,8"
                                     HorizontalOptions="Center"
                                     Spacing="4"
                                     AutomationId="ProjectsTabInvoices">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoInvoicesCommand}" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="tab_invoices.png" WidthRequest="22" HeightRequest="22" />
                    <Label Text="Invoices" TextColor="{StaticResource TabIconMuted}" FontSize="11" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <!-- Reports -->
                <VerticalStackLayout Grid.Column="3"
                                     Padding="0,8"
                                     HorizontalOptions="Center"
                                     Spacing="4"
                                     AutomationId="ProjectsTabReports">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoReportsCommand}" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="tab_reports.png" WidthRequest="22" HeightRequest="22" />
                    <Label Text="Reports" TextColor="{StaticResource TabIconMuted}" FontSize="11" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <!-- Profile -->
                <VerticalStackLayout Grid.Column="4"
                                     Padding="0,8"
                                     HorizontalOptions="Center"
                                     Spacing="4"
                                     AutomationId="ProjectsTabProfile">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoProfileCommand}" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="tab_profile.png" WidthRequest="22" HeightRequest="22" />
                    <Label Text="Profile" TextColor="{StaticResource TabIconMuted}" FontSize="11" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

            </Grid>
        </Border>
    </Grid>
</ContentPage>
