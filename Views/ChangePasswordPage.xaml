<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TestHub.ViewModels"
             x:Class="TestHub.Views.ChangePasswordPage"
             x:DataType="vm:ChangePasswordViewModel"
             Shell.NavBarIsVisible="False"
             Shell.FlyoutBehavior="Disabled"
             Shell.TabBarIsVisible="False"
             BackgroundColor="{StaticResource CardBg}">

    <ContentPage.Resources>
        <Color x:Key="CardBorder">#EAECF2</Color>
        <Color x:Key="MetaText">#64748B</Color>
        <Color x:Key="MutedText">#94A3B8</Color>
        <Color x:Key="LabelText">#64748B</Color>
        <Color x:Key="ErrorText">#DC2626</Color>
        <Color x:Key="SuccessGreen">#10B981</Color>
        <Color x:Key="TipBg">#ECFDF5</Color>
        <Color x:Key="TipBorder">#A7F3D0</Color>
        <Color x:Key="InputBg">#FFFFFF</Color>
        <Color x:Key="InputStroke">#E5E7EB</Color>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="BackgroundColor" Value="{StaticResource White}" />
            <Setter Property="Stroke" Value="{StaticResource CardBorder}" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="StrokeShape">
                <Setter.Value>
                    <RoundRectangle CornerRadius="16" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardTitleStyle" TargetType="Label">
            <Setter Property="TextColor" Value="{StaticResource BrandNavy}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="FontFamily" Value="OpenSansSemibold" />
        </Style>

        <Style x:Key="PasswordFieldStyle" TargetType="Border">
            <Setter Property="BackgroundColor" Value="{StaticResource White}" />
            <Setter Property="Stroke" Value="{StaticResource InputStroke}" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="StrokeShape">
                <Setter.Value>
                    <RoundRectangle CornerRadius="10" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PasswordEntryStyle" TargetType="Entry">
            <Setter Property="BackgroundColor" Value="Transparent" />
            <Setter Property="TextColor" Value="{StaticResource BrandNavy}" />
            <Setter Property="PlaceholderColor" Value="{StaticResource MutedText}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalOptions" Value="Center" />
        </Style>

        <Style x:Key="ErrorLabelStyle" TargetType="Label">
            <Setter Property="TextColor" Value="{StaticResource ErrorText}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- ============================================================ -->
        <!-- HEADER: back arrow + title                                     -->
        <!-- ============================================================ -->
        <Border Grid.Row="0"
                BackgroundColor="{StaticResource White}"
                Stroke="#EAECF2"
                StrokeThickness="0,0,0,1"
                Padding="14,40,14,14">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                <Border Grid.Column="0"
                        BackgroundColor="Transparent"
                        Stroke="Transparent"
                        WidthRequest="40"
                        HeightRequest="40"
                        Padding="0"
                        VerticalOptions="Center"
                        AutomationId="ChangePasswordBack">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding BackCommand}" />
                    </Border.GestureRecognizers>
                    <Image Source="icon_back.png"
                           WidthRequest="20"
                           HeightRequest="20"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
                <Label Grid.Column="1"
                       Text="Change Password"
                       TextColor="{StaticResource BrandNavy}"
                       FontSize="20"
                       FontAttributes="Bold"
                       FontFamily="OpenSansSemibold"
                       VerticalOptions="Center" />
            </Grid>
        </Border>

        <!-- ============================================================ -->
        <!-- BODY                                                           -->
        <!-- ============================================================ -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16,18,16,28" Spacing="16">

                <!-- Tip card -->
                <Border BackgroundColor="{StaticResource TipBg}"
                        Stroke="{StaticResource TipBorder}"
                        StrokeThickness="1"
                        Padding="16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14" />
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Image Grid.Column="0"
                               Source="icon_shield.png"
                               WidthRequest="22"
                               HeightRequest="22"
                               VerticalOptions="Start" />
                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="Keep your account secure"
                                   TextColor="{StaticResource BrandNavy}"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   FontFamily="OpenSansSemibold" />
                            <Label Text="Use a strong password that you don't use elsewhere. We recommend using a password manager."
                                   TextColor="{StaticResource LabelText}"
                                   FontSize="12"
                                   LineHeight="1.4" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Current Password card -->
                <Border Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Current Password" Style="{StaticResource CardTitleStyle}" />

                        <Border Style="{StaticResource PasswordFieldStyle}">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                <Image Grid.Column="0"
                                       Source="icon_lock.png"
                                       WidthRequest="18"
                                       HeightRequest="18"
                                       VerticalOptions="Center" />
                                <Entry Grid.Column="1"
                                       Style="{StaticResource PasswordEntryStyle}"
                                       Placeholder="Enter current password"
                                       IsPassword="{Binding IsCurrentHidden}"
                                       Text="{Binding CurrentPassword, Mode=TwoWay}"
                                       AutomationId="CurrentPasswordEntry" />
                                <Grid Grid.Column="2"
                                      WidthRequest="28"
                                      HeightRequest="28"
                                      VerticalOptions="Center">
                                    <Image Source="icon_eye_off.png"
                                           WidthRequest="20"
                                           HeightRequest="20"
                                           IsVisible="{Binding IsCurrentHidden}" />
                                    <Image Source="icon_eye_open.png"
                                           WidthRequest="20"
                                           HeightRequest="20"
                                           IsVisible="{Binding IsCurrentHidden, Converter={StaticResource InverseBoolConverter}}" />
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ToggleCurrentCommand}" />
                                    </Grid.GestureRecognizers>
                                </Grid>
                            </Grid>
                        </Border>

                        <Label Style="{StaticResource ErrorLabelStyle}"
                               Text="{Binding CurrentPasswordError}"
                               IsVisible="{Binding HasCurrentPasswordError}" />
                    </VerticalStackLayout>
                </Border>

                <!-- New Password card -->
                <Border Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="New Password" Style="{StaticResource CardTitleStyle}" />

                        <Border Style="{StaticResource PasswordFieldStyle}">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                <Image Grid.Column="0"
                                       Source="icon_lock.png"
                                       WidthRequest="18"
                                       HeightRequest="18"
                                       VerticalOptions="Center" />
                                <Entry Grid.Column="1"
                                       Style="{StaticResource PasswordEntryStyle}"
                                       Placeholder="Enter new password"
                                       IsPassword="{Binding IsNewHidden}"
                                       Text="{Binding NewPassword, Mode=TwoWay}"
                                       AutomationId="NewPasswordEntry" />
                                <Grid Grid.Column="2"
                                      WidthRequest="28"
                                      HeightRequest="28"
                                      VerticalOptions="Center">
                                    <Image Source="icon_eye_off.png"
                                           WidthRequest="20"
                                           HeightRequest="20"
                                           IsVisible="{Binding IsNewHidden}" />
                                    <Image Source="icon_eye_open.png"
                                           WidthRequest="20"
                                           HeightRequest="20"
                                           IsVisible="{Binding IsNewHidden, Converter={StaticResource InverseBoolConverter}}" />
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ToggleNewCommand}" />
                                    </Grid.GestureRecognizers>
                                </Grid>
                            </Grid>
                        </Border>

                        <Label Style="{StaticResource ErrorLabelStyle}"
                               Text="{Binding NewPasswordError}"
                               IsVisible="{Binding HasNewPasswordError}" />

                        <Border Style="{StaticResource PasswordFieldStyle}">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                <Image Grid.Column="0"
                                       Source="icon_lock.png"
                                       WidthRequest="18"
                                       HeightRequest="18"
                                       VerticalOptions="Center" />
                                <Entry Grid.Column="1"
                                       Style="{StaticResource PasswordEntryStyle}"
                                       Placeholder="Confirm new password"
                                       IsPassword="{Binding IsConfirmHidden}"
                                       Text="{Binding ConfirmPassword, Mode=TwoWay}"
                                       AutomationId="ConfirmPasswordEntry" />
                                <Grid Grid.Column="2"
                                      WidthRequest="28"
                                      HeightRequest="28"
                                      VerticalOptions="Center">
                                    <Image Source="icon_eye_off.png"
                                           WidthRequest="20"
                                           HeightRequest="20"
                                           IsVisible="{Binding IsConfirmHidden}" />
                                    <Image Source="icon_eye_open.png"
                                           WidthRequest="20"
                                           HeightRequest="20"
                                           IsVisible="{Binding IsConfirmHidden, Converter={StaticResource InverseBoolConverter}}" />
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ToggleConfirmCommand}" />
                                    </Grid.GestureRecognizers>
                                </Grid>
                            </Grid>
                        </Border>

                        <Label Style="{StaticResource ErrorLabelStyle}"
                               Text="{Binding ConfirmPasswordError}"
                               IsVisible="{Binding HasConfirmPasswordError}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Password Requirements card -->
                <Border Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Password Requirements" Style="{StaticResource CardTitleStyle}" />

                        <!-- At least 8 characters -->
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" VerticalOptions="Center">
                            <Grid Grid.Column="0" WidthRequest="20" HeightRequest="20">
                                <Ellipse Stroke="{StaticResource MutedText}"
                                         StrokeThickness="1.5"
                                         Fill="Transparent"
                                         WidthRequest="20"
                                         HeightRequest="20"
                                         IsVisible="{Binding HasMinLength, Converter={StaticResource InverseBoolConverter}}" />
                                <Image Source="icon_check_circle.png"
                                       WidthRequest="20"
                                       HeightRequest="20"
                                       IsVisible="{Binding HasMinLength}" />
                            </Grid>
                            <Label Grid.Column="1"
                                   Text="At least 8 characters"
                                   FontSize="13"
                                   VerticalOptions="Center">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding HasMinLength}" Value="True">
                                        <Setter Property="TextColor" Value="{StaticResource BrandNavy}" />
                                        <Setter Property="FontFamily" Value="OpenSansSemibold" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding HasMinLength}" Value="False">
                                        <Setter Property="TextColor" Value="{StaticResource LabelText}" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </Grid>

                        <!-- One uppercase letter -->
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" VerticalOptions="Center">
                            <Grid Grid.Column="0" WidthRequest="20" HeightRequest="20">
                                <Ellipse Stroke="{StaticResource MutedText}"
                                         StrokeThickness="1.5"
                                         Fill="Transparent"
                                         WidthRequest="20"
                                         HeightRequest="20"
                                         IsVisible="{Binding HasUppercase, Converter={StaticResource InverseBoolConverter}}" />
                                <Image Source="icon_check_circle.png"
                                       WidthRequest="20"
                                       HeightRequest="20"
                                       IsVisible="{Binding HasUppercase}" />
                            </Grid>
                            <Label Grid.Column="1"
                                   Text="One uppercase letter"
                                   FontSize="13"
                                   VerticalOptions="Center">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding HasUppercase}" Value="True">
                                        <Setter Property="TextColor" Value="{StaticResource BrandNavy}" />
                                        <Setter Property="FontFamily" Value="OpenSansSemibold" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding HasUppercase}" Value="False">
                                        <Setter Property="TextColor" Value="{StaticResource LabelText}" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </Grid>

                        <!-- One lowercase letter -->
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" VerticalOptions="Center">
                            <Grid Grid.Column="0" WidthRequest="20" HeightRequest="20">
                                <Ellipse Stroke="{StaticResource MutedText}"
                                         StrokeThickness="1.5"
                                         Fill="Transparent"
                                         WidthRequest="20"
                                         HeightRequest="20"
                                         IsVisible="{Binding HasLowercase, Converter={StaticResource InverseBoolConverter}}" />
                                <Image Source="icon_check_circle.png"
                                       WidthRequest="20"
                                       HeightRequest="20"
                                       IsVisible="{Binding HasLowercase}" />
                            </Grid>
                            <Label Grid.Column="1"
                                   Text="One lowercase letter"
                                   FontSize="13"
                                   VerticalOptions="Center">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding HasLowercase}" Value="True">
                                        <Setter Property="TextColor" Value="{StaticResource BrandNavy}" />
                                        <Setter Property="FontFamily" Value="OpenSansSemibold" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding HasLowercase}" Value="False">
                                        <Setter Property="TextColor" Value="{StaticResource LabelText}" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </Grid>

                        <!-- One number -->
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" VerticalOptions="Center">
                            <Grid Grid.Column="0" WidthRequest="20" HeightRequest="20">
                                <Ellipse Stroke="{StaticResource MutedText}"
                                         StrokeThickness="1.5"
                                         Fill="Transparent"
                                         WidthRequest="20"
                                         HeightRequest="20"
                                         IsVisible="{Binding HasNumber, Converter={StaticResource InverseBoolConverter}}" />
                                <Image Source="icon_check_circle.png"
                                       WidthRequest="20"
                                       HeightRequest="20"
                                       IsVisible="{Binding HasNumber}" />
                            </Grid>
                            <Label Grid.Column="1"
                                   Text="One number"
                                   FontSize="13"
                                   VerticalOptions="Center">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding HasNumber}" Value="True">
                                        <Setter Property="TextColor" Value="{StaticResource BrandNavy}" />
                                        <Setter Property="FontFamily" Value="OpenSansSemibold" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding HasNumber}" Value="False">
                                        <Setter Property="TextColor" Value="{StaticResource LabelText}" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </Grid>

                        <!-- One special character -->
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" VerticalOptions="Center">
                            <Grid Grid.Column="0" WidthRequest="20" HeightRequest="20">
                                <Ellipse Stroke="{StaticResource MutedText}"
                                         StrokeThickness="1.5"
                                         Fill="Transparent"
                                         WidthRequest="20"
                                         HeightRequest="20"
                                         IsVisible="{Binding HasSpecialChar, Converter={StaticResource InverseBoolConverter}}" />
                                <Image Source="icon_check_circle.png"
                                       WidthRequest="20"
                                       HeightRequest="20"
                                       IsVisible="{Binding HasSpecialChar}" />
                            </Grid>
                            <Label Grid.Column="1"
                                   Text="One special character"
                                   FontSize="13"
                                   VerticalOptions="Center">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding HasSpecialChar}" Value="True">
                                        <Setter Property="TextColor" Value="{StaticResource BrandNavy}" />
                                        <Setter Property="FontFamily" Value="OpenSansSemibold" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding HasSpecialChar}" Value="False">
                                        <Setter Property="TextColor" Value="{StaticResource LabelText}" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Update Password (primary) -->
                <Border BackgroundColor="{StaticResource BrandNavy}"
                        Stroke="Transparent"
                        Padding="0,16"
                        AutomationId="UpdatePasswordButton">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SubmitCommand}" />
                    </Border.GestureRecognizers>
                    <Grid HorizontalOptions="Center" VerticalOptions="Center">
                        <Label Text="Update Password"
                               TextColor="{StaticResource White}"
                               FontSize="15"
                               FontAttributes="Bold"
                               FontFamily="OpenSansSemibold"
                               IsVisible="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
                        <ActivityIndicator IsRunning="{Binding IsBusy}"
                                           IsVisible="{Binding IsBusy}"
                                           Color="{StaticResource White}" />
                    </Grid>
                </Border>

                <!-- Cancel (secondary) -->
                <Border BackgroundColor="{StaticResource White}"
                        Stroke="{StaticResource CardBorder}"
                        StrokeThickness="1"
                        Padding="0,16"
                        AutomationId="CancelChangePassword">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding CancelCommand}" />
                    </Border.GestureRecognizers>
                    <Label Text="Cancel"
                           TextColor="{StaticResource BrandNavy}"
                           FontSize="15"
                           FontAttributes="Bold"
                           FontFamily="OpenSansSemibold"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
