<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TestHub.ViewModels"
             x:Class="TestHub.Views.ForgotPasswordPage"
             x:DataType="vm:ForgotPasswordViewModel"
             Shell.NavBarIsVisible="False"
             Shell.FlyoutBehavior="Disabled"
             Shell.TabBarIsVisible="False"
             BackgroundColor="{StaticResource BrandNavy}">

    <ContentPage.Resources>
        <Color x:Key="ErrorRed">#DC2626</Color>
    </ContentPage.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{StaticResource BrandNavyLight}" Offset="0.0" />
                <GradientStop Color="{StaticResource BrandNavy}"      Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollView>
            <Grid HorizontalOptions="Center"
                  VerticalOptions="Start"
                  MaximumWidthRequest="{OnIdiom Phone=480, Tablet=480, Desktop=480, Default=480}"
                  Padding="20,0">

                <VerticalStackLayout Spacing="0">

                    <!-- Back arrow chip -->
                    <Border BackgroundColor="#33FFFFFF"
                            Stroke="Transparent"
                            HorizontalOptions="Start"
                            WidthRequest="44"
                            HeightRequest="44"
                            Margin="0,28,0,0"
                            Padding="0"
                            AutomationId="ForgotBackButton">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="22" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding BackCommand}" />
                        </Border.GestureRecognizers>
                        <Image Source="icon_back.png"
                               WidthRequest="20"
                               HeightRequest="20"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               SemanticProperties.Description="Back" />
                    </Border>

                    <!-- Brand logo -->
                    <Image Source="logo_testhub.png"
                           WidthRequest="96"
                           HeightRequest="96"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           Margin="0,40,0,32"
                           SemanticProperties.Description="TestHub logo">
                        <Image.Shadow>
                            <Shadow Brush="Black" Opacity="0.4" Radius="20" Offset="0,8" />
                        </Image.Shadow>
                    </Image>

                    <!-- Card -->
                    <Border BackgroundColor="{StaticResource CardBg}"
                            Stroke="Transparent"
                            StrokeThickness="0"
                            Padding="24"
                            Margin="0,0,0,20">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" Opacity="0.25" Radius="30" Offset="0,12" />
                        </Border.Shadow>

                        <VerticalStackLayout Spacing="14">

                            <Label Text="Forgot Password"
                                   TextColor="{StaticResource BrandNavy}"
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   FontFamily="OpenSansSemibold"
                                   SemanticProperties.HeadingLevel="Level1" />

                            <Label Text="Please enter your email address, you will receive a link to create a new password via email"
                                   TextColor="{StaticResource MutedText}"
                                   FontSize="14"
                                   LineHeight="1.35"
                                   Margin="0,0,0,4" />

                            <!-- Email field -->
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Email Address" Style="{StaticResource FieldLabelStyle}" />

                                <Border Style="{StaticResource InputBorderStyle}">
                                    <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                                        <Image Source="icon_mail.png"
                                               WidthRequest="20"
                                               HeightRequest="20"
                                               VerticalOptions="Center" />
                                        <Entry x:Name="EmailEntry"
                                               Style="{StaticResource InputEntryStyle}"
                                               Placeholder="you@example.com"
                                               Keyboard="Email"
                                               Text="{Binding Email, Mode=TwoWay}"
                                               WidthRequest="{OnIdiom Phone=260, Default=320}"
                                               AutomationId="ForgotEmailEntry"
                                               SemanticProperties.Description="Email address" />
                                    </HorizontalStackLayout>
                                </Border>

                                <Label Text="{Binding EmailError}"
                                       IsVisible="{Binding HasEmailError}"
                                       TextColor="{StaticResource ErrorRed}"
                                       FontSize="12"
                                       Margin="4,0,0,0" />
                            </VerticalStackLayout>

                            <!-- Submit -->
                            <Grid HeightRequest="52" Margin="0,8,0,0">
                                <Button Text="Submit"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Command="{Binding SubmitCommand}"
                                        IsVisible="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                                        AutomationId="ForgotSubmitButton" />

                                <Border BackgroundColor="{StaticResource BrandNavy}"
                                        Stroke="Transparent"
                                        IsVisible="{Binding IsBusy}">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12" />
                                    </Border.StrokeShape>
                                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                                       Color="{StaticResource White}"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center" />
                                </Border>
                            </Grid>

                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </Grid>
        </ScrollView>
    </Grid>

</ContentPage>
