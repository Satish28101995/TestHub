<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TestHub.Views.SplashPage"
             Shell.NavBarIsVisible="False"
             Shell.FlyoutBehavior="Disabled"
             Shell.TabBarIsVisible="False"
             BackgroundColor="{StaticResource BrandNavy}">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{StaticResource BrandNavyLight}" Offset="0.0" />
                <GradientStop Color="{StaticResource BrandNavy}"      Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <Image x:Name="LogoImage"
               Source="logo_testhub.png"
               WidthRequest="140"
               HeightRequest="140"
               Aspect="AspectFit"
               HorizontalOptions="Center"
               VerticalOptions="Center"
               Opacity="0"
               Scale="0.85"
               SemanticProperties.Description="TestHub logo">
            <Image.Shadow>
                <Shadow Brush="Black"
                        Opacity="0.4"
                        Radius="30"
                        Offset="0,10" />
            </Image.Shadow>
        </Image>
    </Grid>

</ContentPage>
