<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TestHub.ViewModels"
             x:Class="TestHub.Views.SignupPage"
             x:DataType="vm:SignupViewModel"
             Shell.NavBarIsVisible="False"
             Shell.FlyoutBehavior="Disabled"
             Shell.TabBarIsVisible="False"
             BackgroundColor="{StaticResource CardBg}">

    <ContentPage.Resources>
        <Color x:Key="ErrorRed">#DC2626</Color>
        <Color x:Key="LogoUploadBorder">#CBD5E1</Color>

        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="BackgroundColor" Value="{StaticResource White}" />
            <Setter Property="Stroke" Value="Transparent" />
            <Setter Property="StrokeThickness" Value="0" />
            <Setter Property="StrokeShape">
                <Setter.Value>
                    <RoundRectangle CornerRadius="16" />
                </Setter.Value>
            </Setter>
            <Setter Property="Padding" Value="20" />
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- Header strip -->
        <Border Grid.Row="0"
                BackgroundColor="{StaticResource BrandNavy}"
                Stroke="Transparent"
                StrokeThickness="0"
                Padding="16,18,16,22">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,20,20" />
            </Border.StrokeShape>

            <VerticalStackLayout Spacing="14">
                <Grid ColumnDefinitions="Auto,*">
                    <Border Grid.Column="0"
                            BackgroundColor="#33FFFFFF"
                            Stroke="Transparent"
                            WidthRequest="40"
                            HeightRequest="40"
                            Padding="0"
                            VerticalOptions="Center"
                            AutomationId="SignupBackButton">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding BackCommand}" />
                        </Border.GestureRecognizers>
                        <Image Source="icon_back.png"
                               WidthRequest="18"
                               HeightRequest="18"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>

                    <VerticalStackLayout Grid.Column="1"
                                         Spacing="2"
                                         Margin="14,0,0,0"
                                         VerticalOptions="Center">
                        <Label Text="Create Account"
                               TextColor="{StaticResource White}"
                               FontSize="20"
                               FontAttributes="Bold"
                               FontFamily="OpenSansSemibold" />
                        <Label Text="Step 1 of 3"
                               TextColor="#C7D2FE"
                               FontSize="13" />
                    </VerticalStackLayout>
                </Grid>

                <!-- Step progress -->
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8" Margin="0,4,0,0">
                    <Border Grid.Column="0"
                            BackgroundColor="{StaticResource BrandGold}"
                            Stroke="Transparent"
                            HeightRequest="6">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="3" />
                        </Border.StrokeShape>
                    </Border>
                    <Border Grid.Column="1"
                            BackgroundColor="#4B5489"
                            Stroke="Transparent"
                            HeightRequest="6">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="3" />
                        </Border.StrokeShape>
                    </Border>
                    <Border Grid.Column="2"
                            BackgroundColor="#4B5489"
                            Stroke="Transparent"
                            HeightRequest="6">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="3" />
                        </Border.StrokeShape>
                    </Border>
                </Grid>
            </VerticalStackLayout>
        </Border>

        <!-- Form -->
        <ScrollView Grid.Row="1">
            <Grid HorizontalOptions="Center"
                  MaximumWidthRequest="{OnIdiom Phone=480, Tablet=520, Desktop=560, Default=520}"
                  Padding="16,16,16,28">

                <VerticalStackLayout Spacing="16">

                    <!-- Section header: Contractor Profile -->
                    <Border Style="{StaticResource SectionCardStyle}" Padding="16,14">
                        <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                            <Border BackgroundColor="#FCEDC9"
                                    Stroke="Transparent"
                                    WidthRequest="44"
                                    HeightRequest="44"
                                    Padding="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>
                                <Image Source="icon_building.png"
                                       WidthRequest="22"
                                       HeightRequest="22"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                <Label Text="Contractor Profile"
                                       TextColor="{StaticResource BrandNavy}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       FontFamily="OpenSansSemibold" />
                                <Label Text="Let's set up your business information"
                                       TextColor="{StaticResource MutedText}"
                                       FontSize="13" />
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </Border>

                    <!-- Main details card -->
                    <Border Style="{StaticResource SectionCardStyle}">
                        <VerticalStackLayout Spacing="14">

                            <!-- Company logo upload -->
                            <VerticalStackLayout Spacing="10">
                                <Label Text="Company Logo" Style="{StaticResource FieldLabelStyle}" />

                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14" VerticalOptions="Center">
                                    <Border Grid.Column="0"
                                            BackgroundColor="{StaticResource White}"
                                            Stroke="{StaticResource LogoUploadBorder}"
                                            StrokeThickness="1.5"
                                            StrokeDashArray="4,3"
                                            WidthRequest="68"
                                            HeightRequest="68"
                                            Padding="0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="12" />
                                        </Border.StrokeShape>
                                        <Image Source="icon_camera.png"
                                               WidthRequest="26"
                                               HeightRequest="26"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center" />
                                    </Border>

                                    <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                        <Button Text="Upload Logo"
                                                Command="{Binding UploadLogoCommand}"
                                                BackgroundColor="{StaticResource BrandNavy}"
                                                TextColor="{StaticResource White}"
                                                FontFamily="OpenSansSemibold"
                                                FontAttributes="Bold"
                                                FontSize="14"
                                                CornerRadius="10"
                                                HeightRequest="40"
                                                Padding="14,0"
                                                HorizontalOptions="Start"
                                                ImageSource="icon_upload.png"
                                                ContentLayout="Left,8"
                                                AutomationId="SignupUploadLogo" />
                                        <Label Text="PNG, JPG up to 5MB"
                                               TextColor="{StaticResource MutedText}"
                                               FontSize="12"
                                               IsVisible="{Binding HasLogo, Converter={StaticResource InverseBoolConverter}}" />
                                        <Label Text="{Binding LogoFileName}"
                                               TextColor="{StaticResource BrandNavy}"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               FontFamily="OpenSansSemibold"
                                               LineBreakMode="MiddleTruncation"
                                               IsVisible="{Binding HasLogo}" />
                                    </VerticalStackLayout>
                                </Grid>
                            </VerticalStackLayout>

                            <BoxView HeightRequest="1" Color="{StaticResource InputBorder}" Margin="0,4,0,0" />

                            <!-- Company Name -->
                            <VerticalStackLayout Spacing="6">
                                <Label Style="{StaticResource FieldLabelStyle}">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="Company Name " />
                                            <Span Text="*" TextColor="{StaticResource ErrorRed}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                <Border Style="{StaticResource InputBorderStyle}">
                                    <Entry Style="{StaticResource InputEntryStyle}"
                                           Placeholder="ABC Renovations Pty Ltd"
                                           Text="{Binding CompanyName, Mode=TwoWay}"
                                           AutomationId="SignupCompanyName" />
                                </Border>
                                <Label Text="{Binding CompanyNameError}"
                                       IsVisible="{Binding HasCompanyNameError}"
                                       TextColor="{StaticResource ErrorRed}"
                                       FontSize="12" Margin="4,0,0,0" />
                            </VerticalStackLayout>

                            <!-- First Name -->
                            <VerticalStackLayout Spacing="6">
                                <Label Style="{StaticResource FieldLabelStyle}">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="First Name " />
                                            <Span Text="*" TextColor="{StaticResource ErrorRed}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                <Border Style="{StaticResource InputBorderStyle}">
                                    <Entry Style="{StaticResource InputEntryStyle}"
                                           Placeholder="John"
                                           Text="{Binding FirstName, Mode=TwoWay}"
                                           AutomationId="SignupFirstName" />
                                </Border>
                                <Label Text="{Binding FirstNameError}"
                                       IsVisible="{Binding HasFirstNameError}"
                                       TextColor="{StaticResource ErrorRed}"
                                       FontSize="12" Margin="4,0,0,0" />
                            </VerticalStackLayout>

                            <!-- Last Name -->
                            <VerticalStackLayout Spacing="6">
                                <Label Style="{StaticResource FieldLabelStyle}">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="Last Name " />
                                            <Span Text="*" TextColor="{StaticResource ErrorRed}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                <Border Style="{StaticResource InputBorderStyle}">
                                    <Entry Style="{StaticResource InputEntryStyle}"
                                           Placeholder="Smith"
                                           Text="{Binding LastName, Mode=TwoWay}"
                                           AutomationId="SignupLastName" />
                                </Border>
                                <Label Text="{Binding LastNameError}"
                                       IsVisible="{Binding HasLastNameError}"
                                       TextColor="{StaticResource ErrorRed}"
                                       FontSize="12" Margin="4,0,0,0" />
                            </VerticalStackLayout>

                            <!-- Address -->
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Address" Style="{StaticResource FieldLabelStyle}" />
                                <Border Style="{StaticResource InputBorderStyle}">
                                    <Entry Style="{StaticResource InputEntryStyle}"
                                           Placeholder="123 Builder St, Sydney NSW 2000"
                                           Text="{Binding Address, Mode=TwoWay}"
                                           AutomationId="SignupAddress" />
                                </Border>
                            </VerticalStackLayout>

                            <!-- Phone -->
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Phone" Style="{StaticResource FieldLabelStyle}" />
                                <Border Style="{StaticResource InputBorderStyle}">
                                    <Entry Style="{StaticResource InputEntryStyle}"
                                           Placeholder="0400 000 000"
                                           Keyboard="Telephone"
                                           Text="{Binding Phone, Mode=TwoWay}"
                                           AutomationId="SignupPhone" />
                                </Border>
                                <Label Text="{Binding PhoneError}"
                                       IsVisible="{Binding HasPhoneError}"
                                       TextColor="{StaticResource ErrorRed}"
                                       FontSize="12" Margin="4,0,0,0" />
                            </VerticalStackLayout>

                            <!-- Email -->
                            <VerticalStackLayout Spacing="6">
                                <Label Style="{StaticResource FieldLabelStyle}">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="Email " />
                                            <Span Text="*" TextColor="{StaticResource ErrorRed}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                <Border Style="{StaticResource InputBorderStyle}">
                                    <Entry Style="{StaticResource InputEntryStyle}"
                                           Placeholder="john@abcrenovations.com.au"
                                           Keyboard="Email"
                                           Text="{Binding Email, Mode=TwoWay}"
                                           AutomationId="SignupEmail" />
                                </Border>
                                <Label Text="{Binding EmailError}"
                                       IsVisible="{Binding HasEmailError}"
                                       TextColor="{StaticResource ErrorRed}"
                                       FontSize="12" Margin="4,0,0,0" />
                            </VerticalStackLayout>

                            <!-- Website -->
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Website" Style="{StaticResource FieldLabelStyle}" />
                                <Border Style="{StaticResource InputBorderStyle}">
                                    <Entry Style="{StaticResource InputEntryStyle}"
                                           Placeholder="www.abcrenovations.com.au"
                                           Keyboard="Url"
                                           Text="{Binding Website, Mode=TwoWay}"
                                           AutomationId="SignupWebsite" />
                                </Border>
                                <Label Text="{Binding WebsiteError}"
                                       IsVisible="{Binding HasWebsiteError}"
                                       TextColor="{StaticResource ErrorRed}"
                                       FontSize="12" Margin="4,0,0,0" />
                            </VerticalStackLayout>

                            <!-- Password -->
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Password" Style="{StaticResource FieldLabelStyle}" />
                                <Border Style="{StaticResource InputBorderStyle}">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" VerticalOptions="Center">
                                        <Entry Grid.Column="0"
                                               Style="{StaticResource InputEntryStyle}"
                                               Placeholder="Password"
                                               IsPassword="{Binding IsPasswordHidden}"
                                               Text="{Binding Password, Mode=TwoWay}"
                                               AutomationId="SignupPassword" />
                                        <Grid Grid.Column="1"
                                              WidthRequest="32"
                                              HeightRequest="32"
                                              VerticalOptions="Center"
                                              AutomationId="SignupTogglePassword"
                                              SemanticProperties.Description="Toggle password visibility">
                                            <Image Source="icon_eye_off.png"
                                                   WidthRequest="22"
                                                   HeightRequest="22"
                                                   IsVisible="{Binding IsPasswordHidden}" />
                                            <Image Source="icon_eye_open.png"
                                                   WidthRequest="22"
                                                   HeightRequest="22"
                                                   IsVisible="{Binding IsPasswordHidden, Converter={StaticResource InverseBoolConverter}}" />
                                            <Grid.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding TogglePasswordCommand}" />
                                            </Grid.GestureRecognizers>
                                        </Grid>
                                    </Grid>
                                </Border>
                                <Label Text="{Binding PasswordError}"
                                       IsVisible="{Binding HasPasswordError}"
                                       TextColor="{StaticResource ErrorRed}"
                                       FontSize="12" Margin="4,0,0,0" />
                            </VerticalStackLayout>

                            <!-- Confirm password -->
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Confirm Password" Style="{StaticResource FieldLabelStyle}" />
                                <Border Style="{StaticResource InputBorderStyle}">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" VerticalOptions="Center">
                                        <Entry Grid.Column="0"
                                               Style="{StaticResource InputEntryStyle}"
                                               Placeholder="Confirm Password"
                                               IsPassword="{Binding IsConfirmPasswordHidden}"
                                               Text="{Binding ConfirmPassword, Mode=TwoWay}"
                                               AutomationId="SignupConfirmPassword" />
                                        <Grid Grid.Column="1"
                                              WidthRequest="32"
                                              HeightRequest="32"
                                              VerticalOptions="Center"
                                              AutomationId="SignupToggleConfirmPassword"
                                              SemanticProperties.Description="Toggle confirm password visibility">
                                            <Image Source="icon_eye_off.png"
                                                   WidthRequest="22"
                                                   HeightRequest="22"
                                                   IsVisible="{Binding IsConfirmPasswordHidden}" />
                                            <Image Source="icon_eye_open.png"
                                                   WidthRequest="22"
                                                   HeightRequest="22"
                                                   IsVisible="{Binding IsConfirmPasswordHidden, Converter={StaticResource InverseBoolConverter}}" />
                                            <Grid.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding ToggleConfirmPasswordCommand}" />
                                            </Grid.GestureRecognizers>
                                        </Grid>
                                    </Grid>
                                </Border>
                                <Label Text="{Binding ConfirmPasswordError}"
                                       IsVisible="{Binding HasConfirmPasswordError}"
                                       TextColor="{StaticResource ErrorRed}"
                                       FontSize="12" Margin="4,0,0,0" />
                            </VerticalStackLayout>

                        </VerticalStackLayout>
                    </Border>

                    <!-- ABN / ACN / License -->
                    <Border Style="{StaticResource SectionCardStyle}">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="ABN/ACN/License Number"
                                   TextColor="{StaticResource BrandNavy}"
                                   FontFamily="OpenSansSemibold"
                                   FontAttributes="Bold"
                                   FontSize="14" />

                            <Button Text="Upload Document"
                                    Command="{Binding UploadAbnCommand}"
                                    BackgroundColor="{StaticResource BrandNavy}"
                                    TextColor="{StaticResource White}"
                                    FontFamily="OpenSansSemibold"
                                    FontAttributes="Bold"
                                    FontSize="14"
                                    CornerRadius="10"
                                    HeightRequest="40"
                                    Padding="14,0"
                                    HorizontalOptions="Start"
                                    ImageSource="icon_upload.png"
                                    ContentLayout="Left,8"
                                    AutomationId="SignupUploadAbn" />

                            <Label Text="Upload a clear photo of your ABN, ACN, or License document"
                                   TextColor="{StaticResource MutedText}"
                                   FontSize="12"
                                   IsVisible="{Binding HasAbnDocument, Converter={StaticResource InverseBoolConverter}}" />

                            <Label Text="{Binding AbnFileName}"
                                   TextColor="{StaticResource BrandNavy}"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   FontFamily="OpenSansSemibold"
                                   LineBreakMode="MiddleTruncation"
                                   IsVisible="{Binding HasAbnDocument}" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Terms + submit -->
                    <VerticalStackLayout Spacing="12">
                        <HorizontalStackLayout Spacing="2" VerticalOptions="Center">
                            <CheckBox IsChecked="{Binding AcceptTerms, Mode=TwoWay}"
                                      Color="{StaticResource BrandNavy}"
                                      VerticalOptions="Center"
                                      AutomationId="SignupAcceptTerms" />
                            <Label Text="I accept the terms and conditions."
                                   TextColor="{StaticResource BrandNavy}"
                                   FontSize="13"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>

                        <Label Text="{Binding TermsError}"
                               IsVisible="{Binding HasTermsError}"
                               TextColor="{StaticResource ErrorRed}"
                               FontSize="12"
                               Margin="4,-6,0,0" />

                        <Grid HeightRequest="52">
                            <Button Text="Verify Email"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding VerifyEmailCommand}"
                                    IsVisible="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                                    AutomationId="SignupVerifyEmail" />

                            <Border BackgroundColor="{StaticResource BrandNavy}"
                                    Stroke="Transparent"
                                    IsVisible="{Binding IsBusy}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>
                                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                                   Color="{StaticResource White}"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center" />
                            </Border>
                        </Grid>

                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="6" Margin="0,4,0,0">
                            <Label Text="Already have an account?"
                                   TextColor="{StaticResource MutedText}"
                                   FontSize="13"
                                   VerticalOptions="Center" />
                            <Label Text="Sign In"
                                   TextColor="{StaticResource BrandNavy}"
                                   FontAttributes="Bold"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="13"
                                   VerticalOptions="Center"
                                   AutomationId="SignupSignInLink">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SignInCommand}" />
                                </Label.GestureRecognizers>
                            </Label>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Grid>
        </ScrollView>
    </Grid>

</ContentPage>
