<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TestHub.Views.HomePage"
             Shell.NavBarIsVisible="False"
             Title="Home"
             BackgroundColor="{StaticResource BrandNavy}">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{StaticResource BrandNavyLight}" Offset="0.0" />
                <GradientStop Color="{StaticResource BrandNavy}"      Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <VerticalStackLayout HorizontalOptions="Center"
                             VerticalOptions="Center"
                             Spacing="16"
                             Padding="24">

            <Image Source="logo_testhub.png"
                   WidthRequest="96"
                   HeightRequest="96"
                   Aspect="AspectFit"
                   HorizontalOptions="Center"
                   SemanticProperties.Description="TestHub logo" />

            <Label Text="Welcome to TestHub"
                   TextColor="{StaticResource White}"
                   FontSize="26"
                   FontAttributes="Bold"
                   FontFamily="OpenSansSemibold"
                   HorizontalTextAlignment="Center"
                   SemanticProperties.HeadingLevel="Level1" />

            <Label Text="You're signed in."
                   TextColor="{StaticResource BrandGold}"
                   FontSize="15"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>
    </Grid>

</ContentPage>
