<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TestHub.ViewModels"
             x:Class="TestHub.Views.InvoicesListPage"
             x:Name="InvoicesRoot"
             x:DataType="vm:InvoicesListViewModel"
             Shell.NavBarIsVisible="False"
             Shell.FlyoutBehavior="Disabled"
             Shell.TabBarIsVisible="False"
             BackgroundColor="{StaticResource CardBg}">

    <ContentPage.Resources>
        <Color x:Key="MutedText">#94A3B8</Color>
        <Color x:Key="LabelText">#64748B</Color>
        <Color x:Key="TabIconMuted">#9AA3B5</Color>
        <Color x:Key="TabActiveBg">#FBE6B7</Color>
        <Color x:Key="NotifDot">#EF4444</Color>
        <Color x:Key="OutstandingBg">#FFF6E6</Color>
        <Color x:Key="OutstandingBorder">#F59E0B</Color>
        <Color x:Key="HeaderStatBg">#262C54</Color>
        <Color x:Key="ChipInactiveBg">#F1F5F9</Color>
        <Color x:Key="ChipBorder">#E5E7EB</Color>
        <Color x:Key="NonProjectBg">#E5E7EB</Color>
        <Color x:Key="NonProjectText">#475569</Color>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- ============================================================ -->
        <!-- HEADER (navy with Total Invoices / Total Paid + Create)        -->
        <!-- ============================================================ -->
        <Border Grid.Row="0"
                BackgroundColor="{StaticResource BrandNavy}"
                Stroke="Transparent"
                StrokeThickness="0"
                Padding="20,28,20,22">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,28,28" />
            </Border.StrokeShape>
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="{StaticResource BrandNavyLight}" Offset="0.0" />
                    <GradientStop Color="{StaticResource BrandNavy}"      Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>

            <VerticalStackLayout Spacing="16">
                <!-- Title row: "Invoices" + Create -->
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <Label Grid.Column="0"
                           Text="Invoices"
                           TextColor="{StaticResource White}"
                           FontSize="22"
                           FontAttributes="Bold"
                           FontFamily="OpenSansSemibold"
                           VerticalOptions="Center" />

                    <Border Grid.Column="1"
                            BackgroundColor="{StaticResource BrandGold}"
                            Stroke="Transparent"
                            Padding="14,8"
                            VerticalOptions="Center"
                            AutomationId="InvoicesCreateButton">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="999" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding CreateCommand}" />
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                            <Label Text="+"
                                   TextColor="{StaticResource White}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   FontFamily="OpenSansSemibold"
                                   VerticalOptions="Center" />
                            <Label Text="Create"
                                   TextColor="{StaticResource White}"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   FontFamily="OpenSansSemibold"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>
                </Grid>

                <!-- Two header stat tiles -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Border Grid.Column="0"
                            BackgroundColor="{StaticResource HeaderStatBg}"
                            Stroke="#3A4078"
                            StrokeThickness="1"
                            Padding="14">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Total Invoices"
                                   TextColor="#C7CBD7"
                                   FontSize="12"
                                   FontFamily="OpenSansSemibold" />
                            <Label Text="{Binding TotalInvoices}"
                                   TextColor="{StaticResource White}"
                                   FontSize="24"
                                   FontAttributes="Bold"
                                   FontFamily="OpenSansSemibold" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1"
                            BackgroundColor="{StaticResource HeaderStatBg}"
                            Stroke="#3A4078"
                            StrokeThickness="1"
                            Padding="14">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Total Paid"
                                   TextColor="#C7CBD7"
                                   FontSize="12"
                                   FontFamily="OpenSansSemibold" />
                            <Label Text="{Binding TotalPaidDisplay}"
                                   TextColor="{StaticResource White}"
                                   FontSize="24"
                                   FontAttributes="Bold"
                                   FontFamily="OpenSansSemibold" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </VerticalStackLayout>
        </Border>

        <!-- ============================================================ -->
        <!-- BODY (paginated CollectionView)                                -->
        <!-- ============================================================ -->
        <RefreshView Grid.Row="1"
                     IsRefreshing="{Binding IsBusy, Mode=OneWay}"
                     Command="{Binding RefreshCommand}">
            <CollectionView ItemsSource="{Binding Items}"
                            SelectionMode="None"
                            RemainingItemsThreshold="3"
                            RemainingItemsThresholdReachedCommand="{Binding LoadMoreCommand}">

                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
                </CollectionView.ItemsLayout>

                <!-- ===================== HEADER ===================== -->
                <CollectionView.Header>
                    <VerticalStackLayout Padding="16,18,16,4" Spacing="14">

                        <!-- Search + filter chips card -->
                        <Border BackgroundColor="{StaticResource White}"
                                Stroke="#EAECF2"
                                StrokeThickness="1"
                                Padding="14">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>

                            <VerticalStackLayout Spacing="12">
                                <!-- Search input -->
                                <Border BackgroundColor="{StaticResource White}"
                                        Stroke="{StaticResource ChipBorder}"
                                        StrokeThickness="1"
                                        Padding="14,10">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="999" />
                                    </Border.StrokeShape>
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                        <Image Grid.Column="0"
                                               Source="icon_search.png"
                                               WidthRequest="16"
                                               HeightRequest="16"
                                               VerticalOptions="Center" />
                                        <Entry Grid.Column="1"
                                               Placeholder="Search invoices..."
                                               PlaceholderColor="{StaticResource MutedText}"
                                               TextColor="{StaticResource BrandNavy}"
                                               FontSize="14"
                                               BackgroundColor="Transparent"
                                               ReturnType="Search"
                                               Text="{Binding SearchTerm, Mode=TwoWay}"
                                               VerticalOptions="Center" />
                                    </Grid>
                                </Border>

                                <!-- Status chips -->
                                <HorizontalStackLayout Spacing="10">
                                    <!-- All -->
                                    <Border Padding="16,8"
                                            Stroke="{StaticResource ChipBorder}"
                                            StrokeThickness="1"
                                            BackgroundColor="{Binding IsAllSelected, Converter={StaticResource InverseBoolConverter}, ConverterParameter='nope'}"
                                            AutomationId="InvoicesFilterAll">
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding IsAllSelected}" Value="True">
                                                <Setter Property="BackgroundColor" Value="{StaticResource BrandGold}" />
                                                <Setter Property="Stroke" Value="Transparent" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Border" Binding="{Binding IsAllSelected}" Value="False">
                                                <Setter Property="BackgroundColor" Value="{StaticResource White}" />
                                            </DataTrigger>
                                        </Border.Triggers>
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="999" />
                                        </Border.StrokeShape>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding FilterCommand}" CommandParameter="All" />
                                        </Border.GestureRecognizers>
                                        <Label Text="All"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               FontFamily="OpenSansSemibold">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsAllSelected}" Value="True">
                                                    <Setter Property="TextColor" Value="{StaticResource White}" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsAllSelected}" Value="False">
                                                    <Setter Property="TextColor" Value="{StaticResource BrandNavy}" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </Border>

                                    <!-- Paid -->
                                    <Border Padding="16,8"
                                            Stroke="{StaticResource ChipBorder}"
                                            StrokeThickness="1"
                                            AutomationId="InvoicesFilterPaid">
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding IsPaidSelected}" Value="True">
                                                <Setter Property="BackgroundColor" Value="{StaticResource BrandGold}" />
                                                <Setter Property="Stroke" Value="Transparent" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Border" Binding="{Binding IsPaidSelected}" Value="False">
                                                <Setter Property="BackgroundColor" Value="{StaticResource White}" />
                                            </DataTrigger>
                                        </Border.Triggers>
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="999" />
                                        </Border.StrokeShape>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding FilterCommand}" CommandParameter="Paid" />
                                        </Border.GestureRecognizers>
                                        <Label Text="Paid"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               FontFamily="OpenSansSemibold">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsPaidSelected}" Value="True">
                                                    <Setter Property="TextColor" Value="{StaticResource White}" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsPaidSelected}" Value="False">
                                                    <Setter Property="TextColor" Value="{StaticResource BrandNavy}" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </Border>

                                    <!-- Sent -->
                                    <Border Padding="16,8"
                                            Stroke="{StaticResource ChipBorder}"
                                            StrokeThickness="1"
                                            AutomationId="InvoicesFilterSent">
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding IsSentSelected}" Value="True">
                                                <Setter Property="BackgroundColor" Value="{StaticResource BrandGold}" />
                                                <Setter Property="Stroke" Value="Transparent" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Border" Binding="{Binding IsSentSelected}" Value="False">
                                                <Setter Property="BackgroundColor" Value="{StaticResource White}" />
                                            </DataTrigger>
                                        </Border.Triggers>
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="999" />
                                        </Border.StrokeShape>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding FilterCommand}" CommandParameter="Sent" />
                                        </Border.GestureRecognizers>
                                        <Label Text="Sent"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               FontFamily="OpenSansSemibold">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsSentSelected}" Value="True">
                                                    <Setter Property="TextColor" Value="{StaticResource White}" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsSentSelected}" Value="False">
                                                    <Setter Property="TextColor" Value="{StaticResource BrandNavy}" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </Border>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Outstanding banner (shown only when summary has outstanding) -->
                        <Border BackgroundColor="{StaticResource OutstandingBg}"
                                Stroke="{StaticResource OutstandingBorder}"
                                StrokeThickness="1"
                                Padding="14,12"
                                IsVisible="{Binding ShowOutstandingBanner}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Image Grid.Column="0"
                                       Source="icon_alert_filled.png"
                                       WidthRequest="22"
                                       HeightRequest="22"
                                       VerticalOptions="Start" />
                                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                    <Label Text="Outstanding Invoices"
                                           TextColor="{StaticResource BrandNavy}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           FontFamily="OpenSansSemibold" />
                                    <Label Text="{Binding OutstandingAmountDisplay}"
                                           TextColor="{StaticResource LabelText}"
                                           FontSize="12" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>
                </CollectionView.Header>

                <!-- ===================== ITEM TEMPLATE ===================== -->
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:InvoiceListItemViewModel">
                        <Border BackgroundColor="{StaticResource White}"
                                Stroke="#EAECF2"
                                StrokeThickness="1"
                                Padding="16,14"
                                Margin="16,0,16,0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding BindingContext.OpenInvoiceCommand, Source={x:Reference InvoicesRoot}}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>

                            <VerticalStackLayout Spacing="10">

                                <!-- Top row: INV-XXX (+ Non-project) | status pill -->
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <HorizontalStackLayout Grid.Column="0"
                                                           Spacing="8"
                                                           VerticalOptions="Center">
                                        <Label Text="{Binding InvoiceNumber}"
                                               TextColor="{StaticResource BrandNavy}"
                                               FontSize="16"
                                               FontAttributes="Bold"
                                               FontFamily="OpenSansSemibold"
                                               VerticalOptions="Center" />

                                        <Border BackgroundColor="{StaticResource NonProjectBg}"
                                                Stroke="Transparent"
                                                Padding="8,2"
                                                VerticalOptions="Center"
                                                IsVisible="{Binding IsNonProject}">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="999" />
                                            </Border.StrokeShape>
                                            <Label Text="Non-project"
                                                   TextColor="{StaticResource NonProjectText}"
                                                   FontSize="10"
                                                   FontFamily="OpenSansSemibold" />
                                        </Border>
                                    </HorizontalStackLayout>

                                    <Border Grid.Column="1"
                                            BackgroundColor="{Binding StatusBadgeBackground}"
                                            Stroke="Transparent"
                                            Padding="10,4"
                                            VerticalOptions="Center">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="999" />
                                        </Border.StrokeShape>
                                        <Label Text="{Binding StatusBadgeLabel}"
                                               TextColor="{Binding StatusBadgeText}"
                                               FontSize="11"
                                               FontAttributes="Bold"
                                               FontFamily="OpenSansSemibold" />
                                    </Border>
                                </Grid>

                                <!-- Project + customer -->
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="{Binding ProjectLine}"
                                           TextColor="{StaticResource BrandNavy}"
                                           FontSize="14"
                                           FontFamily="OpenSansSemibold" />
                                    <Label Text="{Binding CustomerName}"
                                           TextColor="{StaticResource LabelText}"
                                           FontSize="12" />
                                </VerticalStackLayout>

                                <BoxView HeightRequest="1" Color="#F1F5F9" Margin="0,2,0,0" />

                                <!-- Footer: amount/date columns + PDF + Resend -->
                                <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto"
                                      ColumnSpacing="12">
                                    <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                                        <Label Text="Amount"
                                               TextColor="{StaticResource MutedText}"
                                               FontSize="11" />
                                        <Label Text="{Binding AmountDisplay}"
                                               TextColor="{StaticResource BrandNavy}"
                                               FontSize="14"
                                               FontAttributes="Bold"
                                               FontFamily="OpenSansSemibold" />
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center" Margin="14,0,0,0">
                                        <Label Text="Generated On"
                                               TextColor="{StaticResource MutedText}"
                                               FontSize="11" />
                                        <Label Text="{Binding GeneratedDateDisplay}"
                                               TextColor="{StaticResource BrandNavy}"
                                               FontSize="13" />
                                    </VerticalStackLayout>

                                    <!-- PDF pill -->
                                    <Border Grid.Column="3"
                                            BackgroundColor="{StaticResource White}"
                                            Stroke="{StaticResource ChipBorder}"
                                            StrokeThickness="1"
                                            Padding="12,6"
                                            VerticalOptions="Center"
                                            IsVisible="{Binding ShowPdfButton}">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="999" />
                                        </Border.StrokeShape>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding BindingContext.DownloadPdfCommand, Source={x:Reference InvoicesRoot}}"
                                                CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                            <Image Source="icon_pdf_download.png"
                                                   WidthRequest="13"
                                                   HeightRequest="13"
                                                   VerticalOptions="Center" />
                                            <Label Text="PDF"
                                                   TextColor="{StaticResource BrandNavy}"
                                                   FontSize="12"
                                                   FontAttributes="Bold"
                                                   FontFamily="OpenSansSemibold"
                                                   VerticalOptions="Center" />
                                        </HorizontalStackLayout>
                                    </Border>

                                    <!-- Resend pill -->
                                    <Border Grid.Column="4"
                                            BackgroundColor="{StaticResource White}"
                                            Stroke="{StaticResource ChipBorder}"
                                            StrokeThickness="1"
                                            Padding="12,6"
                                            VerticalOptions="Center"
                                            IsVisible="{Binding ShowResendButton}">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="999" />
                                        </Border.StrokeShape>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding BindingContext.ResendCommand, Source={x:Reference InvoicesRoot}}"
                                                CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                            <Image Source="icon_send.png"
                                                   WidthRequest="13"
                                                   HeightRequest="13"
                                                   VerticalOptions="Center" />
                                            <Label Text="Resend"
                                                   TextColor="{StaticResource BrandNavy}"
                                                   FontSize="12"
                                                   FontAttributes="Bold"
                                                   FontFamily="OpenSansSemibold"
                                                   VerticalOptions="Center" />
                                        </HorizontalStackLayout>
                                    </Border>
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <!-- ===================== FOOTER ===================== -->
                <CollectionView.Footer>
                    <VerticalStackLayout Padding="16,14,16,110" Spacing="8">
                        <ActivityIndicator IsRunning="{Binding IsLoadingMore}"
                                           IsVisible="{Binding IsLoadingMore}"
                                           Color="{StaticResource BrandGold}"
                                           HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </CollectionView.Footer>

                <!-- ===================== EMPTY STATE ===================== -->
                <CollectionView.EmptyView>
                    <Grid Padding="24,40">
                        <VerticalStackLayout Spacing="10" HorizontalOptions="Center" VerticalOptions="Center">
                            <Image Source="icon_doc_tile.png"
                                   WidthRequest="56"
                                   HeightRequest="56"
                                   HorizontalOptions="Center"
                                   Opacity="0.7" />
                            <Label Text="No invoices yet"
                                   TextColor="{StaticResource BrandNavy}"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   FontFamily="OpenSansSemibold"
                                   HorizontalTextAlignment="Center" />
                            <Label Text="Tap “+ Create” to generate your first invoice."
                                   TextColor="{StaticResource MutedText}"
                                   FontSize="12"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Grid>
                </CollectionView.EmptyView>
            </CollectionView>
        </RefreshView>

        <!-- ============================================================ -->
        <!-- TAB BAR (floating rounded pill, Invoices active)               -->
        <!-- ============================================================ -->
        <Border Grid.Row="1"
                BackgroundColor="{StaticResource White}"
                Stroke="#EAECF2"
                StrokeThickness="1"
                Padding="12,8,12,8"
                Margin="14,0,14,16"
                HorizontalOptions="Fill"
                VerticalOptions="End">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="32" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Opacity="0.12" Radius="18" Offset="0,4" />
            </Border.Shadow>

            <Grid ColumnDefinitions="*,*,*,*,*" ColumnSpacing="4">

                <!-- Home -->
                <VerticalStackLayout Grid.Column="0"
                                     Padding="0,8"
                                     HorizontalOptions="Center"
                                     Spacing="4"
                                     AutomationId="InvoicesTabHome">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoHomeCommand}" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="tab_home.png" WidthRequest="22" HeightRequest="22" />
                    <Label Text="Home" TextColor="{StaticResource TabIconMuted}" FontSize="11" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <!-- Projects -->
                <VerticalStackLayout Grid.Column="1"
                                     Padding="0,8"
                                     HorizontalOptions="Center"
                                     Spacing="4"
                                     AutomationId="InvoicesTabProjects">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoProjectsCommand}" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="tab_projects.png" WidthRequest="22" HeightRequest="22" />
                    <Label Text="Projects" TextColor="{StaticResource TabIconMuted}" FontSize="11" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <!-- Invoices (active) -->
                <Border Grid.Column="2"
                        BackgroundColor="{StaticResource TabActiveBg}"
                        Stroke="Transparent"
                        Padding="0,8"
                        AutomationId="InvoicesTabInvoices">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14" />
                    </Border.StrokeShape>
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                        <Grid WidthRequest="24" HeightRequest="24" HorizontalOptions="Center">
                            <Image Source="tab_invoices.png"
                                   WidthRequest="22"
                                   HeightRequest="22" />
                            <Ellipse Fill="{StaticResource NotifDot}"
                                     WidthRequest="6"
                                     HeightRequest="6"
                                     HorizontalOptions="End"
                                     VerticalOptions="Start" />
                        </Grid>
                        <Label Text="Invoices"
                               TextColor="{StaticResource BrandNavy}"
                               FontSize="11"
                               FontAttributes="Bold"
                               FontFamily="OpenSansSemibold"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

                <!-- Reports -->
                <VerticalStackLayout Grid.Column="3"
                                     Padding="0,8"
                                     HorizontalOptions="Center"
                                     Spacing="4"
                                     AutomationId="InvoicesTabReports">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoReportsCommand}" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="tab_reports.png" WidthRequest="22" HeightRequest="22" />
                    <Label Text="Reports" TextColor="{StaticResource TabIconMuted}" FontSize="11" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <!-- Profile -->
                <VerticalStackLayout Grid.Column="4"
                                     Padding="0,8"
                                     HorizontalOptions="Center"
                                     Spacing="4"
                                     AutomationId="InvoicesTabProfile">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoProfileCommand}" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="tab_profile.png" WidthRequest="22" HeightRequest="22" />
                    <Label Text="Profile" TextColor="{StaticResource TabIconMuted}" FontSize="11" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

            </Grid>
        </Border>
    </Grid>
</ContentPage>
