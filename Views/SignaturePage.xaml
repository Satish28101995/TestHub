<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TestHub.ViewModels"
             xmlns:controls="clr-namespace:TestHub.Controls"
             x:Class="TestHub.Views.SignaturePage"
             x:DataType="vm:SignatureViewModel"
             Shell.NavBarIsVisible="False"
             Shell.FlyoutBehavior="Disabled"
             Shell.TabBarIsVisible="False"
             BackgroundColor="{StaticResource CardBg}">

    <ContentPage.Resources>
        <Color x:Key="ProgressMuted">#4B5489</Color>
        <Color x:Key="ClearLink">#9B5C5C</Color>
        <Color x:Key="PadBorder">#D6DAE4</Color>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ============================ HEADER ============================ -->
        <Border Grid.Row="0"
                BackgroundColor="{StaticResource BrandNavy}"
                Stroke="Transparent"
                StrokeThickness="0"
                Padding="20,22,20,18">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,0,0" />
            </Border.StrokeShape>

            <VerticalStackLayout Spacing="12">
                <Label Text="Create Account"
                       TextColor="{StaticResource White}"
                       FontSize="22"
                       FontAttributes="Bold"
                       FontFamily="OpenSansSemibold" />
                <Label Text="Step 2 of 3"
                       TextColor="#C7D2FE"
                       FontSize="13" />

                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8" Margin="0,4,0,0">
                    <Border Grid.Column="0"
                            BackgroundColor="{StaticResource BrandGold}"
                            Stroke="Transparent"
                            HeightRequest="6">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="3" />
                        </Border.StrokeShape>
                    </Border>
                    <Border Grid.Column="1"
                            BackgroundColor="{StaticResource BrandGold}"
                            Stroke="Transparent"
                            HeightRequest="6">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="3" />
                        </Border.StrokeShape>
                    </Border>
                    <Border Grid.Column="2"
                            BackgroundColor="{StaticResource ProgressMuted}"
                            Stroke="Transparent"
                            HeightRequest="6">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="3" />
                        </Border.StrokeShape>
                    </Border>
                </Grid>
            </VerticalStackLayout>
        </Border>

        <!-- ============================ BODY ============================ -->
        <ScrollView Grid.Row="1">
            <Grid HorizontalOptions="Fill"
                  Padding="16,18,16,16">

                <VerticalStackLayout Spacing="14">

                    <!-- Section title row -->
                    <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                        <Border BackgroundColor="#FCEDC9"
                                Stroke="Transparent"
                                WidthRequest="44"
                                HeightRequest="44"
                                Padding="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Image Source="icon_signature.png"
                                   WidthRequest="22"
                                   HeightRequest="22"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                            <Label Text="Digital Signature"
                                   TextColor="{StaticResource BrandNavy}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   FontFamily="OpenSansSemibold" />
                            <Label Text="Create your Digital Signature"
                                   TextColor="{StaticResource MutedText}"
                                   FontSize="13" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>

                    <!-- Existing signature preview (only when one exists and the user hasn't started drawing again) -->
                    <Border BackgroundColor="{StaticResource White}"
                            Stroke="{StaticResource PadBorder}"
                            StrokeThickness="1"
                            Padding="0"
                            HeightRequest="240"
                            IsVisible="{Binding HasExistingSignature}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14" />
                        </Border.StrokeShape>
                        <Image Source="{Binding SignatureUrl}"
                               Aspect="AspectFit"
                               Margin="16" />
                    </Border>

                    <!-- Signature pad (always shown so the user can re-sign) -->
                    <Grid HeightRequest="380">
                        <Border BackgroundColor="{StaticResource White}"
                                Stroke="{StaticResource PadBorder}"
                                StrokeThickness="1"
                                Padding="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>
                            <controls:SignaturePadView x:Name="SignaturePad"
                                                       StrokeColor="{StaticResource BrandNavy}"
                                                       StrokeWidth="2.6"
                                                       AutomationId="SignaturePad" />
                        </Border>

                        <!-- Bottom-right action row over the pad -->
                        <HorizontalStackLayout HorizontalOptions="End"
                                               VerticalOptions="End"
                                               Spacing="10"
                                               Margin="0,0,16,12">
                            <Border BackgroundColor="#F4F5F8"
                                    Stroke="Transparent"
                                    WidthRequest="36"
                                    HeightRequest="36"
                                    Padding="0"
                                    AutomationId="SignatureRotate">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="18" />
                                </Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnRotateTapped" />
                                </Border.GestureRecognizers>
                                <Image Source="icon_rotate.png"
                                       WidthRequest="20"
                                       HeightRequest="20"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       SemanticProperties.Description="Rotate signature 90 degrees" />
                            </Border>

                            <Label Text="Clear"
                                   TextColor="{StaticResource ClearLink}"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   FontFamily="OpenSansSemibold"
                                   VerticalOptions="Center"
                                   AutomationId="SignatureClear">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnClearTapped" />
                                </Label.GestureRecognizers>
                            </Label>
                        </HorizontalStackLayout>
                    </Grid>

                </VerticalStackLayout>
            </Grid>
        </ScrollView>

        <!-- ============================ SUBMIT ============================ -->
        <Grid Grid.Row="2" Padding="16,8,16,16">
            <Grid HeightRequest="56">
                <Button Text="Submit"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Clicked="OnSubmitClicked"
                        IsVisible="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                        AutomationId="SignatureSubmit" />

                <Border BackgroundColor="{StaticResource BrandNavy}"
                        Stroke="Transparent"
                        IsVisible="{Binding IsBusy}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>
                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       Color="{StaticResource White}"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                </Border>
            </Grid>
        </Grid>

    </Grid>

</ContentPage>
