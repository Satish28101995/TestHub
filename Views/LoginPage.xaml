<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TestHub.ViewModels"
             x:Class="TestHub.Views.LoginPage"
             x:DataType="vm:LoginViewModel"
             Shell.NavBarIsVisible="False"
             Shell.FlyoutBehavior="Disabled"
             Shell.TabBarIsVisible="False"
             BackgroundColor="{StaticResource BrandNavy}">

    <ContentPage.Resources>
        <!-- Page-local helpers (kept here because they only matter on this screen). -->
        <Color x:Key="IconMuted">#9CA3AF</Color>
        <Color x:Key="DividerColor">#D1D5DB</Color>
    </ContentPage.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{StaticResource BrandNavyLight}" Offset="0.0" />
                <GradientStop Color="{StaticResource BrandNavy}"      Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollView>
            <Grid HorizontalOptions="Center"
                  VerticalOptions="Start"
                  MaximumWidthRequest="{OnIdiom Phone=480, Tablet=480, Desktop=480, Default=480}"
                  Padding="20,0">

                <VerticalStackLayout Spacing="0">

                    <!-- Brand logo -->
                    <Image Source="logo_testhub.png"
                           WidthRequest="80"
                           HeightRequest="80"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           Margin="0,60,0,16"
                           SemanticProperties.Description="TestHub logo">
                        <Image.Shadow>
                            <Shadow Brush="Black" Opacity="0.4" Radius="20" Offset="0,8" />
                        </Image.Shadow>
                    </Image>

                    <!-- Title -->
                    <Label Text="Welcome Back"
                           TextColor="{StaticResource White}"
                           FontSize="30"
                           FontAttributes="Bold"
                           FontFamily="OpenSansSemibold"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           SemanticProperties.HeadingLevel="Level1" />

                    <!-- Subtitle -->
                    <Label Text="Sign in to continue your journey"
                           TextColor="{StaticResource BrandGold}"
                           FontSize="15"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           Margin="0,8,0,28" />

                    <!-- Card -->
                    <Border BackgroundColor="{StaticResource CardBg}"
                            Stroke="Transparent"
                            StrokeThickness="0"
                            Padding="24"
                            Margin="0,0,0,20">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" Opacity="0.25" Radius="30" Offset="0,12" />
                        </Border.Shadow>

                        <VerticalStackLayout Spacing="16">

                            <!-- Email field -->
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Email Address" Style="{StaticResource FieldLabelStyle}" />

                                <Border Style="{StaticResource InputBorderStyle}">
                                    <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                                        <Label Text="&#x2709;"
                                               TextColor="{StaticResource IconMuted}"
                                               FontSize="18"
                                               VerticalOptions="Center" />
                                        <Entry x:Name="EmailEntry"
                                               Style="{StaticResource InputEntryStyle}"
                                               Placeholder="you@example.com"
                                               Keyboard="Email"
                                               Text="{Binding Email, Mode=TwoWay}"
                                               WidthRequest="{OnIdiom Phone=260, Default=320}"
                                               AutomationId="LoginEmailEntry"
                                               SemanticProperties.Description="Email address" />
                                    </HorizontalStackLayout>
                                </Border>
                            </VerticalStackLayout>

                            <!-- Password field -->
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Password" Style="{StaticResource FieldLabelStyle}" />

                                <Border Style="{StaticResource InputBorderStyle}">
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10" VerticalOptions="Center">
                                        <Label Grid.Column="0"
                                               Text="&#x1F512;"
                                               TextColor="{StaticResource IconMuted}"
                                               FontSize="16"
                                               VerticalOptions="Center" />
                                        <Entry Grid.Column="1"
                                               x:Name="PasswordEntry"
                                               Style="{StaticResource InputEntryStyle}"
                                               Placeholder="Enter your password"
                                               IsPassword="{Binding IsPasswordHidden}"
                                               Text="{Binding Password, Mode=TwoWay}"
                                               AutomationId="LoginPasswordEntry"
                                               SemanticProperties.Description="Password" />
                                        <Label Grid.Column="2"
                                               Text="&#x1F441;"
                                               TextColor="{StaticResource IconMuted}"
                                               FontSize="18"
                                               VerticalOptions="Center"
                                               AutomationId="LoginTogglePassword"
                                               SemanticProperties.Description="Toggle password visibility">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding TogglePasswordCommand}" />
                                            </Label.GestureRecognizers>
                                        </Label>
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>

                            <!-- Remember me + Forgot password -->
                            <Grid ColumnDefinitions="*,*">
                                <HorizontalStackLayout Grid.Column="0" Spacing="4" VerticalOptions="Center">
                                    <CheckBox IsChecked="{Binding RememberMe, Mode=TwoWay}"
                                              Color="{StaticResource BrandNavy}"
                                              VerticalOptions="Center"
                                              AutomationId="LoginRememberMe" />
                                    <Label Text="Remember me"
                                           TextColor="{StaticResource MutedText}"
                                           FontSize="13"
                                           VerticalOptions="Center" />
                                </HorizontalStackLayout>

                                <Label Grid.Column="1"
                                       Text="Forgot Password?"
                                       TextColor="{StaticResource BrandNavy}"
                                       FontAttributes="Bold"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="13"
                                       HorizontalOptions="End"
                                       VerticalOptions="Center"
                                       AutomationId="LoginForgotPassword">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ForgotPasswordCommand}" />
                                    </Label.GestureRecognizers>
                                </Label>
                            </Grid>

                            <!-- Sign In -->
                            <Grid HeightRequest="52">
                                <Button Text="Sign In"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Command="{Binding SignInCommand}"
                                        IsVisible="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                                        AutomationId="LoginSignInButton"
                                        SemanticProperties.Description="Sign in to TestHub" />

                                <Border BackgroundColor="{StaticResource BrandNavy}"
                                        Stroke="Transparent"
                                        IsVisible="{Binding IsBusy}">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12" />
                                    </Border.StrokeShape>
                                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                                       Color="{StaticResource White}"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center" />
                                </Border>
                            </Grid>

                            <!-- Divider -->
                            <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="12" VerticalOptions="Center">
                                <BoxView Grid.Column="0"
                                         HeightRequest="1"
                                         Color="{StaticResource DividerColor}"
                                         VerticalOptions="Center" />
                                <Label Grid.Column="1"
                                       Text="Or continue with"
                                       TextColor="{StaticResource MutedText}"
                                       FontSize="12" />
                                <BoxView Grid.Column="2"
                                         HeightRequest="1"
                                         Color="{StaticResource DividerColor}"
                                         VerticalOptions="Center" />
                            </Grid>

                            <!-- Social row -->
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                <Border Grid.Column="0"
                                        Style="{StaticResource SocialButtonStyle}"
                                        AutomationId="LoginGoogleButton">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding GoogleSignInCommand}" />
                                    </Border.GestureRecognizers>
                                    <HorizontalStackLayout Spacing="8"
                                                           HorizontalOptions="Center"
                                                           VerticalOptions="Center">
                                        <Label Text="G"
                                               TextColor="{StaticResource BrandNavy}"
                                               FontSize="18"
                                               FontAttributes="Bold"
                                               FontFamily="OpenSansSemibold"
                                               VerticalOptions="Center" />
                                        <Label Text="Google"
                                               TextColor="{StaticResource BrandNavy}"
                                               FontSize="15"
                                               FontAttributes="Bold"
                                               FontFamily="OpenSansSemibold"
                                               VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                </Border>

                                <Border Grid.Column="1"
                                        Style="{StaticResource SocialButtonStyle}"
                                        AutomationId="LoginAppleButton">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding AppleSignInCommand}" />
                                    </Border.GestureRecognizers>
                                    <HorizontalStackLayout Spacing="8"
                                                           HorizontalOptions="Center"
                                                           VerticalOptions="Center">
                                        <Label Text="&#xF8FF;"
                                               TextColor="{StaticResource BrandNavy}"
                                               FontSize="18"
                                               VerticalOptions="Center" />
                                        <Label Text="Apple"
                                               TextColor="{StaticResource BrandNavy}"
                                               FontSize="15"
                                               FontAttributes="Bold"
                                               FontFamily="OpenSansSemibold"
                                               VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                </Border>
                            </Grid>

                            <!-- Footer -->
                            <HorizontalStackLayout HorizontalOptions="Center" Spacing="6">
                                <Label Text="Don't have an account?"
                                       TextColor="{StaticResource MutedText}"
                                       FontSize="13"
                                       VerticalOptions="Center" />
                                <Label Text="Sign Up"
                                       TextColor="{StaticResource BrandNavy}"
                                       FontAttributes="Bold"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="13"
                                       VerticalOptions="Center"
                                       AutomationId="LoginSignUpLink">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SignUpCommand}" />
                                    </Label.GestureRecognizers>
                                </Label>
                            </HorizontalStackLayout>

                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </Grid>
        </ScrollView>
    </Grid>

</ContentPage>
