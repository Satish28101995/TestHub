<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="TestHub.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:TestHub"
    xmlns:views="clr-namespace:TestHub.Views"
    Title="TestHub"
    FlyoutBehavior="Disabled"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False">

    <!-- The first ShellContent is the initial visible item. -->
    <ShellContent Route="splash"
                  ContentTemplate="{DataTemplate views:SplashPage}" />

    <ShellContent Route="login"
                  ContentTemplate="{DataTemplate views:LoginPage}" />

    <ShellContent Route="forgotpassword"
                  ContentTemplate="{DataTemplate views:ForgotPasswordPage}" />

    <ShellContent Route="signup"
                  ContentTemplate="{DataTemplate views:SignupPage}" />

    <ShellContent Route="dashboard"
                  ContentTemplate="{DataTemplate views:DashboardPage}" />

    <ShellContent Route="signature"
                  ContentTemplate="{DataTemplate views:SignaturePage}" />

    <ShellContent Route="terms"
                  ContentTemplate="{DataTemplate views:TermsPage}" />

    <ShellContent Route="profile"
                  ContentTemplate="{DataTemplate views:ProfilePage}" />

    <ShellContent Route="newcontract"
                  ContentTemplate="{DataTemplate views:NewContractPage}" />

    <ShellContent Route="contracts"
                  ContentTemplate="{DataTemplate views:ContractsListPage}" />

    <ShellContent Route="projects"
                  ContentTemplate="{DataTemplate views:ProjectsListPage}" />

    <ShellContent Route="invoices"
                  ContentTemplate="{DataTemplate views:InvoicesListPage}" />

    <ShellContent Route="reports"
                  ContentTemplate="{DataTemplate views:ReportsPage}" />

    <ShellContent Route="changepassword"
                  ContentTemplate="{DataTemplate views:ChangePasswordPage}" />

    <ShellContent Route="notifications"
                  ContentTemplate="{DataTemplate views:NotificationsPage}" />

    <ShellContent Route="customerlookup"
                  ContentTemplate="{DataTemplate views:CustomerLookupPage}" />

    <ShellContent Route="home"
                  ContentTemplate="{DataTemplate views:HomePage}" />

</Shell>
